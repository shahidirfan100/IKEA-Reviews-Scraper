{
  "title": "IKEA Reviews Scraper",
  "description": "Scrape customer reviews for a single IKEA product using product URL or product ID.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "url": {
      "title": "Product URL",
      "type": "string",
      "description": "IKEA product URL.",
      "editor": "textfield",
      "prefill": "https://www.ikea.com/gb/en/p/poaeng-armchair-white-stained-oak-veneer-knisa-light-beige-s89286612/"
    },
    "productId": {
      "title": "Product ID",
      "type": "string",
      "description": "IKEA product ID (8 digits).",
      "editor": "textfield",
      "prefill": "89286612"
    },
    "resultsWanted": {
      "title": "Results Wanted",
      "type": "integer",
      "description": "Maximum number of reviews to collect.",
      "editor": "number",
      "minimum": 1,
      "default": 20,
      "prefill": 20
    },
    "maxPages": {
      "title": "Max Pages",
      "type": "integer",
      "description": "Maximum review pages to request.",
      "editor": "number",
      "minimum": 1,
      "default": 3,
      "prefill": 3
    },
    "sortBy": {
      "title": "Sort By",
      "type": "string",
      "description": "submissionOn:desc, submissionOn:asc, primaryRating.ratingValue:desc, or positiveFeedbacksCount:desc.",
      "editor": "textfield",
      "default": "submissionOn:desc",
      "prefill": "submissionOn:desc"
    },
    "proxyConfiguration": {
      "title": "Proxy Configuration",
      "type": "object",
      "description": "Optional proxy settings.",
      "editor": "proxy",
      "default": {
        "useApifyProxy": false
      }
    }
  },
  "required": [],
  "additionalProperties": false
}